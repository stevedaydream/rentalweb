{
  "name": "rental-system",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "concurrently -n \"emulator,vite\" -c \"blue,green\" \"npm run dev:emulator\" \"npm run dev\"",
    "stop": "npx kill-port 8080 4000 4400 9099 9199",
    "dev": "vite",
    "dev:emulator": "firebase emulators:start --import=./emulator-data --export-on-exit=./emulator-data",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "analyze": "cross-env ANALYZE=true vite build",
    "lint": "eslint src --ext .ts,.vue",
    "lint:fix": "eslint src --ext .ts,.vue --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,css}\""
  },
  "dependencies": {
    "@sentry/vue": "^10.45.0",
    "axios": "^1.13.2",
    "firebase": "^12.7.0",
    "html2canvas": "^1.4.1",
    "lucide-vue-next": "^0.562.0",
    "pinia": "^3.0.4",
    "uuid": "^13.0.0",
    "vue": "^3.5.24",
    "vue-router": "^4.6.4",
    "vue3-signature": "^0.4.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-pwa": "^1.2.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.1.4"
  }
}
