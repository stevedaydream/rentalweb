rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================
    // 1. 輔助函式
    // =========================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isLandlord() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'landlord';
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 安全存取：欄位不存在時回傳 '' 而非 undefined/null
    function safeField(field) {
      return resource.data.get(field, '');
    }

    // 資料是否屬於當前使用者（用於 get/update/delete）
    function isOwner(field) {
      return isSignedIn() && safeField(field) == request.auth.uid;
    }

    // 新建資料是否屬於當前使用者
    function isCreatingOwn(field) {
      return isSignedIn() && request.resource.data[field] == request.auth.uid;
    }

    // 資料的 landlordId 是否等於當前使用者（用於 update/delete）
    function isLandlordData() {
      return isSignedIn() && safeField('landlordId') == request.auth.uid;
    }

    // 新建資料的 landlordId 是否等於當前使用者（用於 create）
    function isCreatingAsLandlord() {
      return isSignedIn() && request.resource.data.landlordId == request.auth.uid;
    }

    // =========================================================
    // 2. 集合規則
    // =========================================================

    // 用戶資料 (users)
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if request.auth.uid == userId || isLandlord() || isAdmin();
    }

    // 報修單 (repair_requests)
    match /repair_requests/{ticketId} {
      allow read: if isAdmin()
        || (isSignedIn() && (
          safeField('landlordId') == request.auth.uid ||
          safeField('tenantId')   == request.auth.uid
        ));
      allow create: if isAdmin()
        || (isSignedIn() && (
          request.resource.data.landlordId == request.auth.uid ||
          request.resource.data.tenantId   == request.auth.uid
        ));
      allow update: if isAdmin()
        || (isSignedIn() && safeField('landlordId') == request.auth.uid);
      allow delete: if isAdmin()
        || (isSignedIn() && safeField('landlordId') == request.auth.uid);
    }

    // 社區公告 (announcements)
    match /announcements/{id} {
      allow read: if isSignedIn();
      allow create: if isAdmin()
        || (isSignedIn() && request.resource.data.landlordId == request.auth.uid);
      allow update, delete: if isAdmin() || isLandlordData();
    }

    // 台電帳單 (taipower_bills)
    match /taipower_bills/{id} {
      allow read, update, delete: if isAdmin() || isLandlordData();
      allow create: if isAdmin() || isCreatingAsLandlord();
    }

    // 帳務帳單 (bills)
    match /bills/{id} {
      allow read: if isAdmin()
        || (isSignedIn() && (
          safeField('landlordId') == request.auth.uid ||
          safeField('tenantId')   == request.auth.uid
        ));
      allow create: if isAdmin() || isCreatingAsLandlord();
      allow update, delete: if isAdmin() || isLandlordData();
    }

    // 舊報修 (maintenance)
    match /maintenance/{ticketId} {
      allow read: if isAdmin() || isLandlord() || isOwner('tenantId');
      allow create: if isAdmin() || isLandlord() || isCreatingOwn('tenantId');
      allow update: if isAdmin() || isLandlord() || isOwner('tenantId');
      allow delete: if isAdmin() || isLandlord();
    }

    // 訊息 (messages)
    match /messages/{messageId} {
      allow read: if isAdmin()
        || (isSignedIn() && (
          safeField('landlordId') == request.auth.uid ||
          safeField('tenantId')   == request.auth.uid
        ));
      allow create: if isAdmin() || isLandlord() || isCreatingOwn('tenantId');
      allow update, delete: if isAdmin() || isLandlordData();
    }

    // 系統設定 (settings) — 非 LINE 相關的全域設定
    match /settings/{docId} {
      allow read, write: if isAdmin() || isLandlord();
    }

    // LINE Bot 設定 (line_configs) — 每位房東各自的 Channel Secret / Token
    match /line_configs/{landlordId} {
      allow read, write: if request.auth.uid == landlordId || isAdmin();
    }

    // 租客評價 (reviews)
    match /reviews/{reviewId} {
      // 任何人可讀已公開的評價；房東可讀所有自己的評價
      allow read: if resource.data.isVisible == true
        || (isSignedIn() && resource.data.landlordId == request.auth.uid)
        || isAdmin();
      // 任何人（包含未登入）可新增評價，但不可自訂 isVisible / landlordReply
      allow create: if request.resource.data.isVisible == true
        && request.resource.data.landlordReply == null
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
      // 僅房東可更新（隱藏/回覆）、管理員可操作
      allow update, delete: if (isSignedIn() && resource.data.landlordId == request.auth.uid) || isAdmin();
    }

    // 公開房東 Profile (public_profiles) — 供未登入訪客讀取 lineBotId 等公開資訊
    match /public_profiles/{uid} {
      allow read: if true;
      allow write: if request.auth.uid == uid || isAdmin();
    }

    // 房間資料 (rooms)
    match /rooms/{roomId} {
      // 公開且空置的房間可不登入讀取（供找房頁使用）
      allow read: if isSignedIn()
        || (resource.data.isPublic == true && resource.data.status == 'vacant');
      allow create: if isAdmin() || isCreatingAsLandlord();
      allow update, delete: if isAdmin() || isLandlordData();
    }

    // 抄表紀錄 (meter_readings)
    // 租客只能讀自己房東名下的抄表紀錄（users.landlordId == meter_readings.landlordId）
    // roomId 未存於 users 文件，無法在規則層做更細粒度的房間隔離，改以 landlordId 範圍限制
    match /meter_readings/{readingId} {
      allow read: if isAdmin()
        || isLandlordData()
        || (isSignedIn() &&
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('landlordId', '') != '' &&
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('landlordId', '') == resource.data.landlordId);
      allow create: if isAdmin() || isCreatingAsLandlord();
      allow update, delete: if isAdmin() || isLandlordData();
    }

    // 租客資料 (tenants)
    match /tenants/{tenantDocId} {
      allow read: if isAdmin()
        || isLandlord()
        || isOwner('uid')
        || safeField('landlordId') == request.auth.uid;
      allow create: if isAdmin() || isCreatingAsLandlord();
      allow update, delete: if isAdmin() || isLandlordData();
    }

    // 合約 (contracts)
    match /contracts/{contractId} {
      allow read: if isAdmin()
        || (isSignedIn() && safeField('landlordId') == request.auth.uid)
        || (isSignedIn() && safeField('tenantId')   == request.auth.uid);
      allow create: if isAdmin() || isCreatingAsLandlord();
      allow update, delete: if isAdmin() || isLandlordData();
    }

    // 合約範本 (contract_templates) — 每位房東一份，doc ID = landlordId
    match /contract_templates/{uid} {
      allow read, write: if isAdmin() || request.auth.uid == uid;
    }

    // 已簽署合約存檔 (signed_contracts)
    match /signed_contracts/{id} {
      allow read: if isAdmin()
        || resource.data.landlordUid == request.auth.uid
        // 租客：自己的房東 landlordId 與合約 landlordUid 相符即可讀取
        || (isSignedIn() &&
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('landlordId', '') == resource.data.get('landlordUid', ''));
      allow update, delete: if isAdmin()
        || resource.data.landlordUid == request.auth.uid;
      allow create: if isAdmin()
        || request.resource.data.landlordUid == request.auth.uid;
    }

    // LINE 綁定碼 (line_bindings)
    match /line_bindings/{code} {
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow read, delete: if isSignedIn() && safeField('uid') == request.auth.uid;
    }

  }
}
